{
  "name": "shelf",
  "version": "0.1.0",
  "private": true,
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"sleep 2 && SHELF_DEV=1 electron .\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build",
    "start": "vite build && electron .",
    "dist": "vite build && electron-builder --mac --dir",
    "build:native": "npx node-gyp rebuild --directory=native --target=$(node -e \"process.stdout.write(require('electron/package.json').version)\") --arch=arm64 --dist-url=https://electronjs.org/headers"
  },
  "build": {
    "appId": "com.ben.shelf",
    "productName": "Shelf",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dir",
      "identity": null
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "native/build/Release/touch_remap.node",
        "to": "native/touch_remap.node"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "node-addon-api": "^8.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "node-gyp": "^12.2.0",
    "vite": "^6.2.4"
  }
}
